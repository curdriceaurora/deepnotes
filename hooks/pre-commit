#!/usr/bin/env bash
# Pre-commit: lint staged Swift files
set -euo pipefail

STAGED=$(git diff --cached --name-only --diff-filter=ACM | grep '\.swift$' || true)
[ -z "$STAGED" ] && exit 0

echo "==> SwiftFormat (check staged files)"
echo "$STAGED" | xargs swiftformat --lint --config .swiftformat

echo "==> SwiftLint (staged files)"
echo "$STAGED" | xargs swiftlint lint --strict --config .swiftlint.yml

echo "✓ Pre-commit checks passed"
